# Ignore all generated files under outputs/ but keep the directory by committing a placeholder
outputs/**
!outputs/.gitkeep

# Ignore cpython bytecode caches for the project and the patcheval package
__pycache__/
patcheval/__pycache__/

# Common extras
.DS_Store
*.pyc
*.pyo
*.pyd
env/
venv/
.venv/
logs/
claude-code-proxy/uv.lock
evaluation/process_data/*
evaluation/results/*

# Experiment artifact directories (generated by run_infer.sh / run_eval.sh)
evaluation_output/
evaluation/process_datas/

# Local secrets (Claude subscription OAuth token) - never commit
.env.local
.env

# Cloned third-party harness (defending-code-reference-harness)
third_party/

# Cross-validation scratch
.codex_review_prompt.md
.codex_review_out.txt

# Image-pull logs (download_images.py)
pull_images.log
pull.log

# Local run config (copy from config.example.yaml; contains credentials)
config.yaml